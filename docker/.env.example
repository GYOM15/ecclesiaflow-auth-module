# =============================================================================
# ECCLESIAFLOW KEYCLOAK - DOCKER ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in the secrets.
#
# The init-realm.sh script replaces __PLACEHOLDER__ values in the realm
# template at container startup. Secrets are never baked into committed files.
#
# Generate secrets with:  openssl rand -hex 32
# =============================================================================
#
# PRODUCTION CHECKLIST — adjust these values in the deployment branch:
# ─────────────────────────────────────────────────────────────────────
#  1. docker-compose.keycloak.yml → command: start (not start-dev)
#  2. SSL_REQUIRED=external          (or "all" if full HTTPS)
#  3. KC_PROXY=edge                  (uncomment — behind nginx/traefik)
#  4. KC_HOSTNAME=auth.example.com   (public hostname)
#  5. KC_HOSTNAME_PORT=443           (HTTPS port)
#  6. FRONTEND_REDIRECT_URI_*        (production URLs, not localhost)
#  7. FRONTEND_ORIGIN_*              (production origins, not localhost)
#  8. GOOGLE/FACEBOOK redirect URIs  (update in provider consoles too)
#  9. KEYCLOAK_ADMIN_PASSWORD        (strong secret, rotated regularly)
# 10. All *_SECRET / *_PASSWORD      (unique per environment)
# ─────────────────────────────────────────────────────────────────────
# init-realm.sh detects "start-dev" vs "start" automatically:
#   - start-dev → patches master realm sslRequired=NONE (Docker Desktop fix)
#   - start     → exec Keycloak as PID 1 (no patch, production-safe)
# =============================================================================

# ---------------------------------------------------------------------------
# Keycloak Admin Credentials (REQUIRED)
# ---------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Keycloak Database (REQUIRED)
# ---------------------------------------------------------------------------
KEYCLOAK_DB_PASSWORD=
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USERNAME=keycloak

# ---------------------------------------------------------------------------
# Client Secrets (REQUIRED — generate with: openssl rand -hex 32)
# ---------------------------------------------------------------------------
KEYCLOAK_BACKEND_CLIENT_SECRET=
KEYCLOAK_ADMIN_SERVICE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# SMTP — Gmail (REQUIRED for forgot password / email verification)
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
# ---------------------------------------------------------------------------
KEYCLOAK_SMTP_FROM=your-email@gmail.com
KEYCLOAK_SMTP_USER=your-email@gmail.com
KEYCLOAK_SMTP_PASSWORD=

# ---------------------------------------------------------------------------
# Network (optional — defaults shown)
# ---------------------------------------------------------------------------
KEYCLOAK_HOST_PORT=8180
KC_HOSTNAME=localhost
KC_HOSTNAME_PORT=8180
KC_HTTP_ENABLED=true
# Uncomment KC_PROXY=edge when behind a reverse proxy (Keycloak 23.x).
# KC_PROXY_HEADERS is a Keycloak 24+ option — ignored in 23.0.
# KC_PROXY=edge

# SSL requirement for realm-level OIDC endpoints.
# Dev: "none" (default) — allows HTTP from any IP (Docker Desktop workaround).
# Prod: "external" (HTTPS for external IPs) or "all" (HTTPS everywhere).
SSL_REQUIRED=none

# ---------------------------------------------------------------------------
# Google Identity Provider (optional — leave empty to disable)
# Create credentials: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:8180/realms/ecclesiaflow/broker/google/endpoint
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Facebook Identity Provider (optional — leave empty to disable)
# Create app: https://developers.facebook.com/apps/
# Redirect URI: http://localhost:8180/realms/ecclesiaflow/broker/facebook/endpoint
# ---------------------------------------------------------------------------
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Frontend Redirect URIs (optional — defaults for local dev)
# ---------------------------------------------------------------------------
FRONTEND_REDIRECT_URI_1=http://localhost:3000/*
FRONTEND_REDIRECT_URI_2=http://localhost:4200/*
FRONTEND_REDIRECT_URI_3=http://localhost:5173/*

# ---------------------------------------------------------------------------
# Frontend CORS Origins (optional — defaults for local dev)
# ---------------------------------------------------------------------------
FRONTEND_ORIGIN_1=http://localhost:3000
FRONTEND_ORIGIN_2=http://localhost:4200
FRONTEND_ORIGIN_3=http://localhost:5173
