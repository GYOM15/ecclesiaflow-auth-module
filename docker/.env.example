# =============================================================================
# ECCLESIAFLOW KEYCLOAK - DOCKER ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in the secrets.
#
# NOTE: realm-ecclesiaflow.json uses ${PLACEHOLDER} for client secrets.
# For quick local setup, replace the placeholders in the JSON file with
# real secrets matching the values below. A proper init script will be
# provided to automate this.
# =============================================================================

# Keycloak Admin Credentials (REQUIRED - no defaults)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=

# Keycloak Database (REQUIRED - no defaults)
KEYCLOAK_DB_PASSWORD=

# Backend Client Secret (REQUIRED - generate with: openssl rand -hex 32)
KEYCLOAK_BACKEND_CLIENT_SECRET=

# Admin Service Client Secret (REQUIRED - generate with: openssl rand -hex 32)
KEYCLOAK_ADMIN_SERVICE_CLIENT_SECRET=

# Frontend Redirect URIs (optional, defaults to localhost for dev)
FRONTEND_REDIRECT_URI_1=http://localhost:3000/*
FRONTEND_REDIRECT_URI_2=http://localhost:4200/*
FRONTEND_REDIRECT_URI_3=http://localhost:5173/*

# Frontend Origins (optional, defaults to localhost for dev)
FRONTEND_ORIGIN_1=http://localhost:3000
FRONTEND_ORIGIN_2=http://localhost:4200
FRONTEND_ORIGIN_3=http://localhost:5173
