{
  "realm": "ecclesiaflow",
  "enabled": true,
  "displayName": "EcclesiaFlow",
  "displayNameHtml": "<strong>EcclesiaFlow</strong>",
  "sslRequired": "__SSL_REQUIRED__",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": true,
  "registrationEmailAsUsername": true,
  "loginTheme": "ecclesiaflow-user",
  "emailTheme": "ecclesiaflow-base",
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "roles": {
    "realm": [
      {
        "name": "SUPER_ADMIN",
        "description": "Platform administrator with full system access",
        "composite": false
      },
      {
        "name": "SUPPORT",
        "description": "Support staff with read access for troubleshooting",
        "composite": false
      },
      {
        "name": "USER",
        "description": "Authenticated user with verified account (not church member)",
        "composite": false
      }
    ]
  },
  "defaultRoles": ["USER"],
  "clients": [
    {
      "clientId": "ecclesiaflow-backend",
      "name": "EcclesiaFlow Backend Services",
      "description": "Confidential client for backend microservices",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "__KEYCLOAK_BACKEND_CLIENT_SECRET__",
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "300",
        "client.session.idle.timeout": "1800",
        "client.session.max.lifespan": "36000"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "ecclesiaflow-admin-service",
      "name": "EcclesiaFlow Admin Service",
      "description": "Service account used by Auth Module to call Keycloak Admin API and authenticate users via Direct Grant (server-to-server only, for initial password setup)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__KEYCLOAK_ADMIN_SERVICE_CLIENT_SECRET__"
    },
    {
      "clientId": "ecclesiaflow-frontend",
      "name": "EcclesiaFlow Frontend Application",
      "description": "Confidential client for Next.js BFF (server-side). Supports OIDC Authorization Code + PKCE and Direct Grant for password-setup auto-login.",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__KEYCLOAK_FRONTEND_CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "__FRONTEND_REDIRECT_URI_1__",
        "__FRONTEND_REDIRECT_URI_2__",
        "__FRONTEND_REDIRECT_URI_3__"
      ],
      "webOrigins": [
        "__FRONTEND_ORIGIN_1__",
        "__FRONTEND_ORIGIN_2__",
        "__FRONTEND_ORIGIN_3__"
      ],
      "attributes": {
        "access.token.lifespan": "300",
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "__FRONTEND_POST_LOGOUT_REDIRECT_URI__"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "user.attribute": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "identity-provider-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usersessionmodel-note-mapper",
          "consentRequired": false,
          "config": {
            "user.session.note": "identity_provider",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "claim.name": "identity_provider",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "service-account-ecclesiaflow-admin-service",
      "enabled": true,
      "serviceAccountClientId": "ecclesiaflow-admin-service",
      "clientRoles": {
        "realm-management": ["view-users", "query-users", "manage-users"]
      }
    }
  ],
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "oauth2DeviceCodeLifespan": 600,
  "oauth2DevicePollingInterval": 5,
  "smtpServer": {
    "host": "smtp.gmail.com",
    "port": "587",
    "from": "__KEYCLOAK_SMTP_FROM__",
    "fromDisplayName": "EcclesiaFlow",
    "replyTo": "__KEYCLOAK_SMTP_FROM__",
    "auth": "true",
    "user": "__KEYCLOAK_SMTP_USER__",
    "password": "__KEYCLOAK_SMTP_PASSWORD__",
    "starttls": "true",
    "ssl": "false"
  },
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "__GOOGLE_CLIENT_ID__",
        "clientSecret": "__GOOGLE_CLIENT_SECRET__",
        "defaultScope": "openid email profile",
        "syncMode": "FORCE",
        "useJwksUrl": "true"
      }
    },
    {
      "alias": "facebook",
      "displayName": "Facebook",
      "providerId": "facebook",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "__FACEBOOK_CLIENT_ID__",
        "clientSecret": "__FACEBOOK_CLIENT_SECRET__",
        "defaultScope": "email,public_profile",
        "syncMode": "FORCE"
      }
    }
  ],
  "eventsEnabled": true,
  "eventsListeners": ["jboss-logging", "email"],
  "enabledEventTypes": [
    "UPDATE_PASSWORD",
    "RESET_PASSWORD",
    "LOGIN_ERROR"
  ],
  "eventsExpiration": 604800,
  "internationalizationEnabled": true,
  "supportedLocales": ["en", "fr"],
  "defaultLocale": "en"
}
