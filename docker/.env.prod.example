# =============================================================================
# ECCLESIAFLOW — PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.prod and fill in the secrets.
#
#   cp docker/.env.prod.example docker/.env.prod
#
# Generate secrets with:  openssl rand -hex 32
# NEVER commit .env.prod to version control!
# =============================================================================

# =============================================================================
# DOMAIN
# =============================================================================
NGINX_HOST=auth.your-domain.com

# =============================================================================
# AUTH MODULE — Spring Boot
# =============================================================================
# Database credentials (must match MySQL section below)
MYSQL_DATABASE=ecclesiaflow_auth
MYSQL_USER=ecclesiaflow
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# JPA
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=false

# Keycloak Admin API (Service Account)
KEYCLOAK_ADMIN_REALM=ecclesiaflow
KEYCLOAK_ADMIN_SERVICE_CLIENT_ID=ecclesiaflow-admin-service
# NOTE: KEYCLOAK_ADMIN_SERVICE_CLIENT_SECRET is defined once in the Keycloak
# section below. The same value is shared by both the Auth Module and Keycloak.

# gRPC
GRPC_MEMBERS_HOST=members-module
GRPC_MEMBERS_PORT=9091
GRPC_CLIENT_SHUTDOWN_TIMEOUT=5
GRPC_SERVER_PORT=9090
GRPC_SERVER_SHUTDOWN_TIMEOUT=30

# CORS — your frontend domain(s), comma-separated
CORS_ALLOWED_ORIGINS=https://your-domain.com

# Token TTL
AUTH_TOKEN_SETUP_TTL_HOURS=24

# =============================================================================
# KEYCLOAK — Identity Provider
# =============================================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
KC_HOSTNAME=auth.your-domain.com

# Keycloak database (PostgreSQL)
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USERNAME=keycloak
KEYCLOAK_DB_PASSWORD=

# Client secrets (shared between Auth Module and Keycloak — set once here)
KEYCLOAK_BACKEND_CLIENT_SECRET=
KEYCLOAK_ADMIN_SERVICE_CLIENT_SECRET=

# SMTP — Email (Gmail App Password recommended)
KEYCLOAK_SMTP_FROM=noreply@your-domain.com
KEYCLOAK_SMTP_USER=your-email@gmail.com
KEYCLOAK_SMTP_PASSWORD=

# Frontend URIs (your production frontend)
FRONTEND_REDIRECT_URI_1=https://your-domain.com/*
FRONTEND_REDIRECT_URI_2=
FRONTEND_REDIRECT_URI_3=
FRONTEND_ORIGIN_1=https://your-domain.com
FRONTEND_ORIGIN_2=
FRONTEND_ORIGIN_3=

# =============================================================================
# VERSIONING
# =============================================================================
APP_VERSION=latest
