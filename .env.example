# =============================================================================
# ECCLESIAFLOW AUTH MODULE - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#
# IMPORTANT: NEVER commit .env files!
# =============================================================================

# =============================================================================
# SPRING PROFILE
# =============================================================================
# Options: dev, test, prod
SPRING_PROFILES_ACTIVE=dev

# =============================================================================
# APPLICATION
# =============================================================================
AUTH_PASSWORD_SETUP_ENDPOINT=/ecclesiaflow/auth/password/setup
ECCLESIAFLOW_MEMBERS_BASE_URL=http://localhost:8080

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=localhost
DB_PORT=3306
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:8889/auth_module_db
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# JPA/Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

# =============================================================================
# KEYCLOAK OAUTH2 CONFIGURATION
# =============================================================================
# Keycloak server URLs
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/ecclesiaflow
KEYCLOAK_JWKS_URI=http://localhost:8180/realms/ecclesiaflow/protocol/openid-connect/certs
KEYCLOAK_ACCOUNT_URL=http://localhost:8180/realms/ecclesiaflow/account

# Keycloak Admin API (Service Account)
# IMPORTANT: client secret must match the value in docker/.env
KEYCLOAK_ADMIN_SERVER_URL=http://localhost:8180
KEYCLOAK_ADMIN_REALM=ecclesiaflow
KEYCLOAK_ADMIN_SERVICE_CLIENT_ID=ecclesiaflow-admin-service
KEYCLOAK_ADMIN_SERVICE_CLIENT_SECRET=
KEYCLOAK_ADMIN_GRANT_TYPE=client_credentials

# =============================================================================
# gRPC CONFIGURATION
# =============================================================================
# gRPC Clients
GRPC_MEMBERS_HOST=localhost
GRPC_MEMBERS_PORT=9091
GRPC_EMAIL_HOST=localhost
GRPC_EMAIL_PORT=9092
GRPC_CLIENT_SHUTDOWN_TIMEOUT=5

# gRPC Server
GRPC_SERVER_PORT=9090
GRPC_SERVER_SHUTDOWN_TIMEOUT=30

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# =============================================================================
# TOKEN CONFIGURATION
# =============================================================================
# Setup token TTL (hours)
AUTH_TOKEN_SETUP_TTL_HOURS=24